<?xml version="1.0" ?>
<ruleset name="ProjectNeptune">

    <!-- Tell phpcs where to find the custom sniffs -->
    <config name="installed_paths" value="php/Vsm,vendor/slevomat/coding-standard" />


    <!-- Sniff all the folders with PHP code -->
    <file>app</file>
    <file>bin</file>
    <file>php</file>
    <file>public</file>
    <file>tests</file>


    <!-- Exclusions -->
    <exclude-pattern>php/Vsm/External/GoogleAuthenticator.php</exclude-pattern> <!-- This is temporary until we can spin it off into an open source project -->
    <exclude-pattern>php/Vsm/Sniffs/**/*.php</exclude-pattern> <!-- We are not subjecting custom phpcs sniffs to a full machine code review -->

