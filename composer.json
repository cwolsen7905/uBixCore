{
	"name": "ubixsys/ubixcore",
    "description": "uBix Core - The last repo!",
    "type": "library",
    "license": "VSM License",
    "authors": [
      {
        "name": "Christopher W. Olsen",
        "email": "cwolsen@uBixSys.com"
      }
    ],
    "autoload": {
      "psr-4": {
        "PHP_CodeSniffer\\": "vendor/squizlabs/php_codesniffer/src/",
        "Ubix\\": "php/Ubix/",
        "Ubix\\Tests\\": "tests/"
      }
    },
	"minimum-stability": "dev",
	"prefer-stable": true,
	"require": {
		"php": "^8.3",
		"akrabat/proxy-detection-middleware": "^1.0",
		"latte/latte": "^3.0",
		"monolog/monolog": "^3.6",
		"slim/psr7": "^1.4.0",
		"slim/slim": "^4.5",
		"filestack/filestack-php": "^1.1",
		"psr/simple-cache": "^3.0",
		"symfony/cache": "^7.3",
		"symfony/console": "^6.4",
		"psr/http-client": "^1.0",
		"psr/http-message": "^1.1",
		"psr/http-factory": "^1.1",
		"nyholm/psr7": "^1.8",
		"vlucas/phpdotenv": "^5.1",
		"php-di/php-di": "7.0.11",
		"php-di/slim-bridge": "^3.4",
		"guzzlehttp/guzzle": "^7.8",
		"m4tthumphrey/php-gitlab-api":"^12.0",
		"symfony/mailer": "^7.3",
		"symfony/validator": "^7.3",
		"symfony/serializer": "^7.3",
		"symfony/property-access": "^7.3",
		"aws/aws-sdk-php": "^3",
		"ramsey/uuid": "^4.9",
		"fig/http-message-util": "^1.1",
		"symfony/yaml": "^7.3"
	},
	"require-dev": {
		"phpunit/phpunit": "^12.2",
		"phpstan/phpstan": "^2.1",
		"squizlabs/php_codesniffer": "^3.13",
		"slevomat/coding-standard": "^8.19",
		"rector/rector": "^2.1"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"php-http/discovery": true
		}
	}
}