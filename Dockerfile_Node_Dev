# Use Node.js image
FROM node:20

# Set the working directory inside the container
WORKDIR /app
# Copy package.json and install dependencies
COPY package*.json ./
RUN npm install
# Copy the rest of the application
COPY . .
# Build the Svelte app
RUN npm run build
# Expose the port
EXPOSE 5173
# Command to run the app
CMD ["npm", "run", "start"]